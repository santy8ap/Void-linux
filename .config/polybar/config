[colors]
; ── Catppuccin Mocha (mismo que bspwm borders) ───────────────────
base     = #1e1e2e
surface0 = #313244
surface1 = #45475a
overlay1 = #7f849c
text     = #cdd6f4
subtext  = #bac2de
accent   = #cba6f7
blue     = #89b4fa
green    = #a6e3a1
red      = #f38ba8
yellow   = #f9e2af

; D9 = 85% opacidad — semi-transparente con picom
background = #D91e1e2e
foreground = ${colors.subtext}
suffix     = ${colors.red}

[settings]
screenchange-reload = true

[global/wm]
margin-top    = 0
margin-bottom = 0

[bar/top]
monitor          = ${env:MONITOR:}
monitor-fallback = VGA-1
width            = 100%
height           = 22
offset-x         = 0
offset-y         = 0
fixed-center     = true
bottom           = false
locale           = es_CO.UTF-8

background = ${colors.background}
foreground = ${colors.foreground}

line-size  = 2
line-color = ${colors.accent}

border-size  = 0
border-color = #00000000

padding-left  = 1
padding-right = 1
module-margin = 2

; JetBrains NF para texto, FA6 para íconos específicos
font-0 = "JetBrainsMonoNL Nerd Font:style=Regular:size=9;3"
font-1 = "Font Awesome 6 Free:style=Solid:pixelsize=10;3"
font-2 = "Font Awesome 6 Brands:pixelsize=9;2"
font-3 = "JetBrainsMono Nerd Font Mono:pixelsize=9;2"

modules-left   = app cpu memory
modules-center = bspwm
modules-right  = updates openweathermap-forecast pulseaudio fs xkeyboard date tray power

cursor-click      = pointer
cursor-scroll     = ns-resize
override-redirect = false
enable-ipc        = true
wm-restack        = bspwm

; Systray — aparecen nm-applet, blueman, udiskie


[module/app]
type             = custom/text
label            = 
label-font       = 1
label-foreground = ${colors.accent}
label-background = ${colors.surface0}
label-padding    = 3
click-left       = rofi -modi run,drun -show drun -location 1 -xoffset 15 -yoffset 44


[module/cpu]
type                     = internal/cpu
interval                 = 2
format-prefix            = " "
format-prefix-font       = 1
format-prefix-foreground = ${colors.accent}
label                    = %percentage%%


[module/memory]
type                     = internal/memory
interval                 = 2
format-prefix            = " "
format-prefix-font       = 1
format-prefix-foreground = ${colors.accent}
label                    = %percentage_used%%


[module/openweathermap-forecast]
type                     = custom/script
format-prefix            = " "
format-prefix-font       = 1
format-prefix-foreground = ${colors.accent}
exec                     = ~/.config/polybar/scripts/openweathermap-forecast.sh
interval                 = 600
label-font               = 1


[module/bspwm]
type    = internal/bspwm
ws-icon-0 = I;I
ws-icon-1 = II;II
ws-icon-2 = III;III
ws-icon-3 = IV;IV
ws-icon-4 = V;V
ws-icon-5 = VI;VI
ws-icon-6 = VII;VII
ws-icon-7 = VIII;VIII
ws-icon-8 = IX;IX
ws-icon-9 = X;X
ws-icon-default = 

format = <label-state> <label-mode>

label-focused            = %icon%
label-focused-background = ${colors.surface0}
label-focused-foreground = ${colors.accent}
label-focused-underline  = ${colors.accent}
label-focused-padding    = 2

label-occupied            = %icon%
label-occupied-foreground = ${colors.subtext}
label-occupied-padding    = 2

label-urgent              = %icon%
label-urgent-foreground   = ${colors.red}
label-urgent-padding      = 2

label-empty               = 
label-empty-foreground    = ${colors.overlay1}
label-empty-padding       = 2

index-sort      = true
wrapping-scroll = false


[module/pulseaudio]
type          = internal/pulseaudio
use-ui-max    = true
interval      = 5
format-volume = <ramp-volume> <label-volume>
label-volume  = %percentage%%

label-muted            = " muted"
label-muted-font       = 1
label-muted-foreground = ${colors.red}

ramp-volume-0          = 
ramp-volume-1          = 
ramp-volume-2          = 
ramp-volume-font       = 1
ramp-volume-foreground = ${colors.accent}

click-right = pavucontrol &


[module/fs]
type                             = internal/fs
mount-0                          = /
interval                         = 10
fixed-values                     = true
format-mounted-prefix            = " "
format-mounted-prefix-font       = 1
format-mounted-prefix-foreground = ${colors.accent}
label-mounted                    = %free%
format-unmounted-prefix          = " "
format-unmounted-prefix-foreground = ${colors.red}
label-unmounted                  = N/M


[module/date]
type             = internal/date
interval         = 1
date-alt         = "%e %B %Y,"
time             = "%H:%M"
time-alt         = "%H:%M:%S"
format-prefix    = " "
format-prefix-font = 1
format-prefix-foreground = ${colors.accent}
label            = %date% %time%


[module/xkeyboard]
type                     = internal/xkeyboard
blacklist-0              = num lock
blacklist-1              = caps lock
format-prefix            = " "
format-prefix-font       = 1
format-prefix-foreground = ${colors.accent}
label                    = %layout%


[module/power]
type             = custom/text
label            = 
label-font       = 1
label-foreground = ${colors.accent}
label-background = ${colors.surface0}
label-padding    = 3
click-left       = rofi -show power-menu -modi "power-menu:~/.config/polybar/scripts/power-menu.sh"


[module/updates]
type             = custom/script
exec             = ~/.config/polybar/scripts/xbps-updates
format-prefix    = " "
format-prefix-font = 1
format-prefix-foreground = ${colors.accent}
label            = %output%
label-foreground = ${colors.accent}
interval         = 3600
cursor-click     = pointer
click-left       = "st -e sudo xbps-install -Su &"

[module/tray]
type = internal/tray
tray-size = 14
