[global]
    monitor    = 0
    follow     = mouse

    width      = 320
    height     = (0, 280)
    origin     = top-right
    offset     = 16, 48
    notification_limit = 4

    indicate_hidden    = yes
    shrink             = no
    separator_height   = 1
    padding            = 14
    horizontal_padding = 14
    text_icon_padding  = 10

    frame_width  = 1
    frame_color  = "#45475a"
    separator_color = "#45475a"
    corner_radius   = 10
    sort            = yes

    font        = JetBrainsMonoNL Nerd Font 9
    line_height = 2
    markup      = full
    format      = "<b>%s</b>\n%b"
    alignment   = left
    vertical_alignment = center
    word_wrap   = yes
    ellipsize   = middle
    stack_duplicates     = true
    hide_duplicate_count = false
    show_indicators      = yes

    icon_position  = left
    min_icon_size  = 24
    max_icon_size  = 32
    icon_path = /usr/share/icons/Papirus-Dark/24x24/status/:/usr/share/icons/Papirus-Dark/24x24/devices/:/usr/share/icons/Papirus-Dark/24x24/apps/:/usr/share/icons/Papirus-Dark/symbolic/status/

    sticky_history = yes
    history_length = 20

    mouse_left_click   = close_current
    mouse_middle_click = do_action
    mouse_right_click  = close_all

[urgency_low]
    background  = "#CC1e1e2e"
    foreground  = "#bac2de"
    frame_color = "#45475a"
    timeout     = 4

[urgency_normal]
    background  = "#CC1e1e2e"
    foreground  = "#cdd6f4"
    frame_color = "#585b70"
    timeout     = 5

[urgency_critical]
    background  = "#CC181825"
    foreground  = "#f38ba8"
    frame_color = "#f38ba8"
    timeout     = 10
