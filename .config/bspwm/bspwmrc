#! /bin/sh

bspc monitor -d I II III IV V VI VII VIII IX X

bspc config border_width         2
bspc config window_gap           10
bspc config top_padding          35
bspc config bottom_padding       0
bspc config left_padding         0
bspc config right_padding        0

bspc config automatic_scheme      spiral
bspc config split_ratio           0.5
bspc config borderless_monocle    true
bspc config gapless_monocle       false
bspc config single_monocle        true
bspc config focus_follows_pointer true

# Colores Catppuccin Mocha
bspc config normal_border_color   "#45475a"
bspc config active_border_color   "#89b4fa"
bspc config focused_border_color  "#cba6f7"
bspc config presel_feedback_color "#a6e3a1"

bspc rule -a Gnome-calculator state=floating
bspc rule -a Galculator state=floating
bspc rule -a Gpick state=floating
bspc rule -a GParted state=floating
bspc rule -a File-roller state=floating
bspc rule -a Nitrogen state=floating
bspc rule -a Lxappearance state=floating center=true
bspc rule -a Lxrandr state=floating
bspc rule -a Pavucontrol state=floating
bspc rule -a Timeshift-gtk state=floating
bspc rule -a qt5ct state=floating rectangle=700x470+0+0 center=on
bspc rule -a SimpleScreenRecorder state=floating
bspc rule -a Nsxiv state=floating
bspc rule -a Viewnior state=floating
bspc rule -a SMPlayer state=floating
bspc rule -a mpv state=floating sticky=on rectangle=300x180+1060+475

bspc rule -a Steam               state=floating
bspc rule -a Blueman-manager     state=floating
bspc rule -a polybar manage=off
bspc rule -a Tint2 border=off manage=off layer=above state=floating
bspc rule -a '*:Kunst' sticky=on layer=below border=off focus=off

FLOATING_DESKTOP_ID_5=$(bspc query -D -d '^5')
bspc subscribe node | while read -a msg ; do
  desk_id=${msg[2]}
  wid=${msg[3]}
  [ "$FLOATING_DESKTOP_ID_5" = "$desk_id" ] && bspc node "$wid" -t floating
done &

# Autostart (with duplicate prevention for bspwm restart)
pgrep -x sxhkd > /dev/null || sxhkd -c "$HOME/.config/sxhkd/sxhkdrc" &
pgrep -x dunst > /dev/null || dunst &
pgrep -x flameshot > /dev/null || flameshot &
pgrep -x picom > /dev/null || picom &
pgrep -x numlockx > /dev/null || numlockx &

# Audio (PipeWire)
pgrep -x pipewire >/dev/null || pipewire &

# Polybar
pgrep -x polybar > /dev/null || ~/.config/polybar/launch.sh &

# Applets
pgrep -x nm-applet > /dev/null || nm-applet 2>/dev/null &
pgrep -x blueman-applet > /dev/null || blueman-applet 2>/dev/null &

# USB automount con bandeja
pgrep -x udiskie > /dev/null || udiskie --tray 2>/dev/null &
feh --bg-fill ~/Imágenes/void-anime.webp &
pgrep -x xss-lock > /dev/null || xss-lock -- betterlockscreen -l blur &
sudo cpupower frequency-set -g performance > /dev/null 2>&1 &
